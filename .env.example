# OpenRouter API (兼容 OpenAI SDK，代理 GPT-4o 等模型)
OPENAI_API_KEY=sk-or-v1-xxx
LLM_BASE_URL=https://openrouter.ai/api/v1

# 如果直接用 OpenAI 官方 API，注释掉 LLM_BASE_URL 即可
# OPENAI_API_KEY=sk-xxx
# LLM_BASE_URL=

# Model paths (override defaults if needed)
# QWEN3_TTS_MODEL_PATH=models/qwen3-tts
# FISH_SPEECH_MODEL_PATH=models/fish-speech
# BGE_MODEL_PATH=models/bge-large-zh
